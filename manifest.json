{
  "manifest_version": 3,
  "name": "Bloom Scroll: filter out clutter from your feed",
  "author": "Ranjan Lamichhane",
  "version": "1.1.0",
  "description": "AI-powered Chrome extension that filters off-topic, clickbait & low-value posts from your LinkedIn and X feed in real-time.",
  "content_scripts": [
    {
      "js": [
        "scripts/content.js"
      ],
      "matches": [
        "https://www.linkedin.com/feed/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ]
    }
  ],
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  },
  "action": {
    "default_popup": "./pages/popup.html",
    "default_title": "Bloom Scroll"
  },
  "options_page": "./pages/settings.html",
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.x.ai/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ]
}
